"use client";
import { useState } from "react";
import { menu } from "../data/menu";
import { MenuItem } from "../data/menu";
import { useCart } from "./CartContext";

function ItemPill({ item }: { item: MenuItem }) {
  const { cart, addToCart, increase, decrease } = useCart();
  const [popupOpen, setPopupOpen] = useState(false);

  const cartItem = cart.find((c: any) => c.id === item.id);
  const qty = cartItem?.qty ?? 0;

  const handlePillClick = () => {
    if (qty === 0) {
      addToCart(item);
    }
    setPopupOpen(true);
  };

  return (
    <>
      {/* Pill button */}
      <button
        className={`pill-btn${qty > 0 ? " pill-btn--active" : ""}`}
        onClick={handlePillClick}
        aria-label={`${item.name} — €${item.price.toFixed(2)}`}
      >
        <span className="pill-btn__name">{item.name}</span>
        <span className="pill-btn__price">€{item.price.toFixed(2)}</span>
        {qty > 0 && <span className="pill-btn__qty">{qty}</span>}
        {item.spicy && <span className="pill-btn__flag">🌶</span>}
        {item.vegetarian && !item.spicy && <span className="pill-btn__flag">🌿</span>}
      </button>

      {/* Qty popup */}
      {popupOpen && (
        <>
          <div className="popup-backdrop" onClick={() => setPopupOpen(false)} />
          <div className="popup" role="dialog" aria-label={`Quantità per ${item.name}`}>
            {/* Header */}
            <div className="popup__header">
              <div>
                <p className="popup__name">{item.name}</p>
                <p className="popup__ingredients">{item.ingredients}</p>
              </div>
              <button
                className="popup__close"
                onClick={() => setPopupOpen(false)}
                aria-label="Chiudi"
              >✕</button>
            </div>

            {/* Qty controls */}
            <div className="popup__controls">
              <button
                className="qty-btn qty-btn--minus"
                onClick={() => {
                  decrease(item.name);
                  if (qty <= 1) setPopupOpen(false);
                }}
                aria-label="Diminuisci"
              >−</button>
              <span className="qty-display">{qty}</span>
              <button
                className="qty-btn qty-btn--plus"
                onClick={() => increase(item.name)}
                aria-label="Aumenta"
              >+</button>
            </div>

            {/* Price line */}
            <div className="popup__footer">
              <span className="popup__unit-price">€{item.price.toFixed(2)} cad.</span>
              <span className="popup__total">
                Totale: <strong>€{(item.price * qty).toFixed(2)}</strong>
              </span>
            </div>
          </div>
        </>
      )}

      <style>{`
        /* ── Pill button ── */
        .pill-btn {
          position: relative;
          display: flex;
          align-items: center;
          gap: 8px;
          padding: 10px 14px;
          background: #fff;
          border: 1.5px solid var(--color-parchment, #EDE0CC);
          border-radius: 999px;
          cursor: pointer;
          font-family: var(--font-body, sans-serif);
          transition: border-color .15s, background .15s, transform .15s;
          white-space: nowrap;
          text-align: left;
        }
        .pill-btn:hover {
          border-color: var(--color-tomato, #B03A2E);
          background: #FFF8F7;
          transform: translateY(-1px);
        }
        .pill-btn--active {
          border-color: var(--color-tomato, #B03A2E);
          background: #FFF0EE;
        }
        .pill-btn__name {
          font-size: .88rem;
          font-weight: 500;
          color: var(--color-charcoal, #1C1C1A);
        }
        .pill-btn__price {
          font-size: .8rem;
          color: var(--color-stone, #7A7770);
        }
        .pill-btn__qty {
          position: absolute;
          top: -7px; right: -7px;
          width: 20px; height: 20px;
          background: var(--color-tomato, #B03A2E);
          color: #fff;
          font-size: .65rem;
          font-weight: 700;
          border-radius: 50%;
          display: flex; align-items: center; justify-content: center;
          border: 2px solid #fff;
        }
        .pill-btn__flag {
          font-size: .75rem;
          margin-left: -2px;
        }

        /* ── Popup backdrop ── */
        .popup-backdrop {
          position: fixed; inset: 0; z-index: 200;
          background: rgba(28,28,26,.4);
          backdrop-filter: blur(2px);
          animation: fadeIn .15s ease;
        }

        /* ── Popup card ── */
        .popup {
          position: fixed;
          bottom: 0; left: 0; right: 0;
          z-index: 201;
          background: var(--color-cream, #FDF6EC);
          border-radius: 20px 20px 0 0;
          padding: 24px 24px 36px;
          box-shadow: 0 -8px 40px rgba(28,28,26,.18);
          animation: slideUp .22s cubic-bezier(.22,1,.36,1);
          max-width: 480px;
          margin: 0 auto;
        }
        @keyframes slideUp {
          from { transform: translateY(100%); opacity: 0; }
          to   { transform: translateY(0);    opacity: 1; }
        }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .popup__header {
          display: flex; justify-content: space-between;
          align-items: flex-start; gap: 12px; margin-bottom: 20px;
        }
        .popup__name {
          font-family: var(--font-display, Georgia, serif);
          font-size: 1.1rem; font-weight: 700;
          color: var(--color-charcoal, #1C1C1A);
        }
        .popup__ingredients {
          font-size: .78rem; color: var(--color-stone, #7A7770);
          margin-top: 3px; line-height: 1.4;
        }
        .popup__close {
          background: rgba(28,28,26,.08); border: none;
          width: 32px; height: 32px; border-radius: 50%;
          font-size: .9rem; cursor: pointer; flex-shrink: 0;
          display: flex; align-items: center; justify-content: center;
          color: var(--color-charcoal, #1C1C1A);
          transition: background .15s;
        }
        .popup__close:hover { background: rgba(28,28,26,.15); }

        /* ── Qty controls ── */
        .popup__controls {
          display: flex; align-items: center; justify-content: center;
          gap: 28px; margin-bottom: 20px;
        }
        .qty-btn {
          width: 48px; height: 48px; border-radius: 50%;
          border: 2px solid var(--color-parchment, #EDE0CC);
          background: #fff; font-size: 1.5rem; line-height: 1;
          cursor: pointer; display: flex; align-items: center; justify-content: center;
          color: var(--color-charcoal, #1C1C1A);
          transition: border-color .15s, background .15s;
        }
        .qty-btn:hover { border-color: var(--color-tomato, #B03A2E); }
        .qty-btn--plus {
          background: var(--color-tomato, #B03A2E);
          border-color: var(--color-tomato, #B03A2E);
          color: #fff;
        }
        .qty-btn--plus:hover { background: var(--color-tomato-light, #C9503F); }
        .qty-display {
          font-family: var(--font-display, Georgia, serif);
          font-size: 2rem; font-weight: 700;
          color: var(--color-charcoal, #1C1C1A);
          min-width: 40px; text-align: center;
        }

        /* ── Footer ── */
        .popup__footer {
          display: flex; justify-content: space-between; align-items: center;
          padding-top: 16px;
          border-top: 1px solid var(--color-parchment, #EDE0CC);
        }
        .popup__unit-price { font-size: .82rem; color: var(--color-stone, #7A7770); }
        .popup__total { font-size: .9rem; color: var(--color-charcoal, #1C1C1A); }
        .popup__total strong { color: var(--color-tomato, #B03A2E); font-size: 1.05rem; }
      `}</style>
    </>
  );
}

export default function MenuGrid() {
  return (
    <section className="menu-grid" id="menu">
      <div className="container">
        {menu.map((cat) => (
          <div key={cat.category} className="menu-cat">
            <h2 className="menu-cat__title">
              <span className="menu-cat__emoji">{cat.emoji}</span>
              {cat.category}
            </h2>
            <div className="menu-cat__pills">
              {cat.items.map((item) => (
                <ItemPill key={item.id} item={item} />
              ))}
            </div>
          </div>
        ))}
      </div>

      <style>{`
        .menu-grid {
          padding: 48px 0 64px;
          background: var(--color-cream, #FDF6EC);
        }
        .menu-cat {
          margin-bottom: 36px;
        }
        .menu-cat__title {
          font-family: var(--font-display, Georgia, serif);
          font-size: 1.1rem;
          font-weight: 700;
          color: var(--color-charcoal, #1C1C1A);
          margin-bottom: 14px;
          display: flex;
          align-items: center;
          gap: 8px;
        }
        .menu-cat__emoji { font-size: 1.1rem; }
        .menu-cat__pills {
          display: flex;
          flex-wrap: wrap;
          gap: 8px;
        }
      `}</style>
    </section>
  );
}
