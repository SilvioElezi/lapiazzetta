"use client";

import { MenuItem } from "../data/menu";
import { useCart } from "../components/CartContext";

type Props = {
  item: MenuItem;
};

export default function ProductCard({ item }: Props) {
  const { addToCart } = useCart();

  return (
    <article className="card">
      {/* Badges */}
      {(item.popular || item.spicy || item.vegetarian) && (
        <div className="card__badges">
          {item.popular && <span className="badge badge--popular">⭐ Popolare</span>}
          {item.spicy && <span className="badge badge--spicy">🌶 Piccante</span>}
          {item.vegetarian && <span className="badge badge--veg">🌿 Vegetariana</span>}
        </div>
      )}

      {/* Content */}
      <div className="card__body">
        <div className="card__header">
          <h3 className="card__name">{item.name}</h3>
          <span className="card__price">€{item.price.toFixed(2)}</span>
        </div>

        {item.description && (
          <p className="card__description">{item.description}</p>
        )}

        <p className="card__ingredients">{item.ingredients}</p>
      </div>

      {/* CTA → ADD TO CART */}
      <button
        onClick={() => addToCart(item)}
        className="card__btn"
        aria-label={`Aggiungi ${item.name}`}
      >
        Aggiungi
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          strokeWidth="2.5"
          strokeLinecap="round"
          strokeLinejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </button>

      <style>{`
        .card {
          background: var(--color-surface);
          border: 1px solid var(--color-parchment);
          border-radius: var(--radius-md);
          padding: 20px;
          display: flex;
          flex-direction: column;
          gap: 14px;
          box-shadow: var(--shadow-card);
          transition: transform var(--transition-base), box-shadow var(--transition-base);
          position: relative;
        }
        .card:hover {
          transform: translateY(-3px);
          box-shadow: var(--shadow-card-hover);
        }

        .card__badges {
          display: flex;
          flex-wrap: wrap;
          gap: 6px;
        }

        .badge {
          font-size: 0.68rem;
          padding: 3px 9px;
          border-radius: 999px;
        }

        .badge--popular {
          background: #FEF3DB;
          color: #8A5E12;
        }

        .badge--spicy {
          background: #FDECEA;
          color: #8C2318;
        }

        .badge--veg {
          background: #EBF5EB;
          color: #245524;
        }

        .card__body { flex: 1; }

        .card__header {
          display: flex;
          justify-content: space-between;
          gap: 12px;
        }

        .card__name {
          font-size: 1.05rem;
          font-weight: 700;
        }

        .card__price {
          font-weight: 500;
          color: var(--color-tomato);
        }

        .card__description {
          font-size: 0.78rem;
          font-style: italic;
        }

        .card__ingredients {
          font-size: 0.85rem;
          color: var(--color-stone);
        }

        .card__btn {
          display: inline-flex;
          align-items: center;
          gap: 7px;
          padding: 9px 18px;
          border: 1.5px solid var(--color-tomato);
          border-radius: 999px;
          cursor: pointer;
          background: transparent;
          color: var(--color-tomato);
        }

        .card__btn:hover {
          background: var(--color-tomato);
          color: #fff;
        }
      `}</style>
    </article>
  );
}
